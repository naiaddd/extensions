<script type="application/ld+json">{
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "WebPage",
            "@id": "https://www.servicesaustralia.gov.au/centrelink?context=1",
            "name": "Centrelink",
            "url": "https://www.servicesaustralia.gov.au/centrelink?context=1",
            "breadcrumb": {
                "@type": "BreadcrumbList",
                "itemListElement": [
                    {
                        "@type": "ListItem",
                        "position": 1,
                        "name": "Home",
                        "item": "https://www.servicesaustralia.gov.au/"
                    }
                ]
            },
            "dateModified": "2025-07-03T09:37:34+1000",
            "description": "We have payments and services to support you.",
            "audience": {
                "@type": "Audience",
                "audienceType": "Individuals",
                "alternateName": "individuals"
            },
            "hasPart": [
                {
                    "@type": "WebPage",
                    "@id": "https://www.servicesaustralia.gov.au/get-centrelink-payment?context=1",
                    "name": "Get a Centrelink payment",
                    "description": "Find out about payments and services, setting up online accounts and claiming.",
                    "url": "https://www.servicesaustralia.gov.au/get-centrelink-payment?context=1"
                },
                {
                    "@type": "WebPage",
                    "@id": "https://www.servicesaustralia.gov.au/while-you-wait-for-centrelink-claim-outcome?context=1",
                    "name": "While you wait for a Centrelink claim outcome",
                    "description": "There’s support while you wait to find out about your Centrelink claim outcome.",
                    "url": "https://www.servicesaustralia.gov.au/while-you-wait-for-centrelink-claim-outcome?context=1"
                },
                {
                    "@type": "WebPage",
                    "@id": "https://www.servicesaustralia.gov.au/manage-your-centrelink-payment?context=1",
                    "name": "Manage your Centrelink payment",
                    "description": "If you get a payment, you’ll have some regular commitments you need to meet. If you don’t, your payment may stop.",
                    "url": "https://www.servicesaustralia.gov.au/manage-your-centrelink-payment?context=1"
                },
                {
                    "@type": "WebPage",
                    "@id": "https://www.servicesaustralia.gov.au/top-payments-for-centrelink?context=1",
                    "name": "Top payments",
                    "description": "The payments and services most viewed by other website visitors.",
                    "url": "https://www.servicesaustralia.gov.au/top-payments-for-centrelink?context=1"
                },
                {
                    "@type": "WebPage",
                    "@id": "https://www.servicesaustralia.gov.au/most-useful-information-for-centrelink?context=1",
                    "name": "Most useful information",
                    "description": "The pages voted most useful by other website visitors.",
                    "url": "https://www.servicesaustralia.gov.au/most-useful-information-for-centrelink?context=1"
                },
                {
                    "@type": "WebPage",
                    "@id": "https://www.servicesaustralia.gov.au/news-for-centrelink?context=1",
                    "name": "News",
                    "description": "The latest news updates and changes.",
                    "url": "https://www.servicesaustralia.gov.au/news-for-centrelink?context=1"
                }
            ],
            "speakable": {
                "@type": "SpeakableSpecification",
                "xpath": [
                    "/html/head/meta[@name=\u0027description\u0027]/@content",
                    "//*[@id=\u0027lit-short-description\u0027]/p"
                ]
            },
            "mainContentOfPage": {
                "@type": "WebPageElement",
                "cssSelector": "#lit-content-main"
            }
        },
        {
            "@type": "WebSite",
            "@id": "https://www.servicesaustralia.gov.au/",
            "name": "Services Australia",
            "url": "https://www.servicesaustralia.gov.au/",
            "potentialAction": {
                "@type": "SearchAction",
                "target": {
                    "@type": "EntryPoint",
                    "urlTemplate": "https://www.servicesaustralia.gov.au/search?search={search_term_string}"
                },
                "query": "https://www.servicesaustralia.gov.au/search?search={search_term_string}",
                "query-input": "required name=search_term_string"
            }
        }
    ]
}</script>
